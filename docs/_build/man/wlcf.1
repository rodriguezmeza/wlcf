.SS Plotting the 3PCF multipoles
.sp
The output files \fBzetam*.txt\fP contain the multipoles
\ezeta_m(\etheta_1,\etheta_2)\&. These can be visualized as 2D maps:
.INDENT 0.0
.INDENT 3.5
.sp
.EX
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.colors import LogNorm

path = \(dq/home/sadi/LSST/test/wlcf\-main/tests/Bell_outputs\(dq
prefix = \(dqhalo_model_z05078_\(dq

theta = np.loadtxt(f\(dq{path}/{prefix}theta_array.txt\(dq) * 180 / np.pi * 60
Theta2, Theta1 = np.meshgrid(theta, theta)

fig = plt.figure(figsize=(19, 4))

gs = fig.add_gridspec(
    nrows=1,
    ncols=6,
    width_ratios=[1, 1, 1, 1, 1, 0.06],
    wspace=0.25
)

norm = LogNorm(vmin=1e\-11, vmax=1e\-8)

for m in range(5):
    ax = fig.add_subplot(gs[0, m])

    zeta = np.abs(np.loadtxt(f\(dq{path}/{prefix}zetam{m}.txt\(dq))

    im = ax.pcolormesh(
        Theta2,
        Theta1,
        zeta,
        shading=\(dqauto\(dq,
        cmap=\(dqRdYlBu_r\(dq,
        norm=norm
    )

    ax.set_xscale(\(dqlog\(dq)
    ax.set_yscale(\(dqlog\(dq)
    ax.set_xlim(10, 200)
    ax.set_ylim(10, 200)
    ax.set_aspect(\(dqequal\(dq, adjustable=\(dqbox\(dq)
    ax.set_title(fr\(dq$m={m}$\(dq, fontsize=14)

    if m == 0:
        ax.set_ylabel(r\(dq$\etheta_1$ [arcmin]\(dq, fontsize=13)

    ax.set_xlabel(r\(dq$\etheta_2$ [arcmin]\(dq, fontsize=13)

# Colorbar outside the plots
cax = fig.add_subplot(gs[0, \-1])
cbar = fig.colorbar(im, cax=cax)
cbar.set_label(r\(dq$|\ezeta_m|$\(dq, fontsize=13)
cbar.ax.tick_params(labelsize=11)

fig.suptitle(
    \(dqHalo Model: 3PCF Multipoles at z = 0.5078\(dq,
    fontsize=18,
    y=1.02
)
    plt.savefig(\(dqhalo_model_3pcf.png\(dq, dpi=300, bbox_inches=\(dqtight\(dq)
    plt.show()
.EE
