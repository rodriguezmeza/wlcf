base_params = dict(
    numberThreads=8,
    verbose=2,
    verbose_log=1,

    # T17 / paper cosmology
    z=0.5078,
    h=0.7,
    sigma8=0.82,
    Omb=0.046,
    Omc=0.233,
    Omnu=0.0,
    ns=0.97,
    w=\-1.0,

    # Make sure this P(k) was generated with the same cosmology
    fnamePS=\(dq./input/linear_pk_camb_T17_z05078.txt\(dq,

    # Redshift bin
    Wg=0,
    fWgchi=\(dq./input/Wg_Takahashi_z05078.txt\(dq,

    rootDir=\(dqOutput\(dq,
    path_Bells=\(dqBell_outputs\(dq,

    zbin=0.5078,
    mMax=5,
    chiQuadSteps=300,
    GLpoints=64,
    Nell=128,
    ellmax=10000,
    ellmin=0.001,
    writevectors=0,
    chatty=2,
    options=\(dq\(dq
)

models = {
    1: \(dqSPT\(dq,
    2: \(dqTree\(dq,
    3: \(dqEFT\(dq,
    4: \(dqHalo_model\(dq
}

for tree_level, model_name in models.items():

    print(f\(dqRunning {model_name} model with tree_level={tree_level}\(dq)

    params = base_params.copy()
    params[\(dqtree_level\(dq] = tree_level
    params[\(dqprefix\(dq] = f\(dq{model_name.lower()}_z05078_\(dq

    w = wlcf()
    w.set(params)
    w.Run()

    print(f\(dqFinished {model_name}\(dq)
